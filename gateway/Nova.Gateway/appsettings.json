{
  "ConnectionStrings": {
    "Default": "Server=localhost;Database=nova_dev;Uid=root;Pwd=55350530Asd;Port=3306;charset=utf8mb4"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Yarp": "Information"
      }
    }
  },
  "SwaggerEndpoints": {
    "Tenant Service": "/swagger-json/tenant/swagger.json",
    "Identity Service": "/swagger-json/identity/swagger.json",
    "System Service": "/swagger-json/system/swagger.json",
    "Business Service": "/swagger-json/business/swagger.json"
  },
  "ReverseProxy": {
    "Routes": {
      "tenant-swagger-route": {
        "ClusterId": "tenant-cluster",
        "Match": {
          "Path": "/swagger-json/tenant/swagger.json"
        },
        "Transforms": [
          { "PathSet": "/swagger/v1/swagger.json" }
        ]
      },
      "identity-swagger-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/swagger-json/identity/swagger.json"
        },
        "Transforms": [
          { "PathSet": "/swagger/v1/swagger.json" }
        ]
      },
      "system-swagger-route": {
        "ClusterId": "system-cluster",
        "Match": {
          "Path": "/swagger-json/system/swagger.json"
        },
        "Transforms": [
          { "PathSet": "/swagger/v1/swagger.json" }
        ]
      },
      "business-swagger-route": {
        "ClusterId": "business-cluster",
        "Match": {
          "Path": "/swagger-json/business/swagger.json"
        },
        "Transforms": [
          { "PathSet": "/swagger/v1/swagger.json" }
        ]
      },
      "tenant-route": {
        "ClusterId": "tenant-cluster",
        "Match": {
          "Path": "/api/tenant/{**catch-all}"
        }
      },
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/identity/{**catch-all}"
        }
      },
      "system-route": {
        "ClusterId": "system-cluster",
        "Match": {
          "Path": "/api/system/{**catch-all}"
        }
      },
      "business-route": {
        "ClusterId": "business-cluster",
        "Match": {
          "Path": "/api/business/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "tenant-cluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:8082" }
        }
      },
      "identity-cluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:8080" }
        }
      },
      "system-cluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:8081" }
        }
      },
      "business-cluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:8083" }
        }
      }
    }
  }
}
